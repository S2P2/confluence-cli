{
  "name": "@s2p2/confluence-cli",
  "version": "0.1.1",
  "description": "A TypeScript CLI for Atlassian Confluence — fork of pchuri/confluence-cli with blog posts, labels, diagnostics, and grouped commands",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "confluence": "dist/bin/confluence.js",
    "confluence-cli": "dist/bin/confluence.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun run src/index.ts --",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "confluence",
    "atlassian",
    "cli",
    "wiki",
    "documentation"
  ],
  "author": "S2P2",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "form-data": "^4.0.5",
    "html-to-text": "^9.0.5",
    "inquirer": "^8.2.6",
    "markdown-it": "^14.1.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/commander": "^2.12.5",
    "@types/html-to-text": "^9.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "js-yaml": "^4.1.1",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^3.14.2"
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/S2P2/confluence-cli.git"
  },
  "bugs": {
    "url": "https://github.com/S2P2/confluence-cli/issues"
  },
  "homepage": "https://github.com/S2P2/confluence-cli#readme",
  "files": [
    "dist/",
    "plugins/",
    ".claude-plugin/"
  ]
}
